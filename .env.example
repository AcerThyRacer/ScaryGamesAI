# ScaryGamesAI Platform Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/scarygamesai
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================
# REDIS (Caching & Sessions)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key

# ============================================
# STRIPE PAYMENTS
# ============================================
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs for subscriptions
# Create products at https://dashboard.stripe.com/products
PRICE_SURVIVOR_MONTHLY=price_survivor_monthly
PRICE_SURVIVOR_ANNUAL=price_survivor_annual
PRICE_HUNTER_MONTHLY=price_hunter_monthly
PRICE_HUNTER_ANNUAL=price_hunter_annual
PRICE_ELDER_MONTHLY=price_elder_monthly
PRICE_ELDER_ANNUAL=price_elder_annual

# ============================================
# OAUTH PROVIDERS
# ============================================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Discord OAuth
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_CALLBACK_URL=http://localhost:3001/api/auth/discord/callback

# Steam OAuth (for Workshop integration)
STEAM_API_KEY=your-steam-api-key
STEAM_CALLBACK_URL=http://localhost:3001/api/auth/steam/callback

# ============================================
# EMAIL SERVICE
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
EMAIL_FROM=noreply@scarygamesai.com

# ============================================
# CLOUD STORAGE (Optional)
# ============================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=scarygamesai-assets

# ============================================
# ANALYTICS & MONITORING
# ============================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
LOG_LEVEL=info

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_GLOBAL_PER_MINUTE=1000
RATE_LIMIT_API_PER_MINUTE=240
RATE_LIMIT_API_V1_PER_MINUTE=180
RATE_LIMIT_API_V2_PER_MINUTE=300
RATE_LIMIT_AUTH_PER_MINUTE=10

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_STRIPE=true
ENABLE_OAUTH=true
ENABLE_CLOUD_SAVE=true
ENABLE_MULTIPLAYER=true
ENABLE_WORKSHOP=false
