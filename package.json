{
  "name": "scarygamesai-platform",
  "version": "2.0.0",
  "description": "AAA Browser-Based Horror Gaming Platform",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "start:dev": "concurrently \"npm run dev\" \"node server.js\"",
    "optimize": "node scripts/optimize-assets.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "db:init": "psql -f schema.sql",
    "setup": "node scripts/setup.js"
  },
  "dependencies": {
    "three": "^0.160.0",
    "@ffmpeg/ffmpeg": "^0.12.0",
    "socket.io-client": "^4.6.0",
    "express": "^4.18.2",
    "stripe": "^14.0.0",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "pg": "^8.11.3",
    "redis": "^4.6.10"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "vite-plugin-static-copy": "^1.0.0",
    "sharp": "^0.33.0",
    "vitest": "^1.0.0",
    "@playwright/test": "^1.40.0",
    "eslint": "^8.56.0",
    "@vitest/coverage-v8": "^1.0.0",
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
